# ============================================================================
# ABX Motion — env vars
# Sharing the ABX-Motion Firebase project (docucraft-cd41b) and the same
# Cloudflare R2 bucket (ABX-Motion-uploads) — one auth, one bill.
# ============================================================================

# ---------- Frontend (Vite exposes only VITE_* to the browser) ----------
VITE_FB_API_KEY=
VITE_FB_AUTH_DOMAIN=
VITE_FB_PROJECT_ID=
VITE_FB_STORAGE_BUCKET=
VITE_FB_MESSAGING_SENDER_ID=
VITE_FB_APP_ID=

VITE_R2_PUBLIC_BASE=
VITE_R2_UPLOAD_ENDPOINT=

# ---------- Server-only (Vercel env) ----------
APP_URL=https://abxmotion.io
ALLOWED_ORIGINS=https://abxmotion.io,https://www.abxmotion.io

# Firebase Admin — paste the service-account JSON, base64-encoded.
# (cat firebase-adminsdk-xxx.json | base64 | tr -d '\n')
FIREBASE_PROJECT_ID=docucraft-cd41b
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Cloudflare R2 (admin deletes + seed script). The browser does NOT use these.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE=
R2_UPLOAD_ENDPOINT=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email (Resend) — optional
RESEND_API_KEY=
RESEND_FROM=ABX Motion <orders@abxmotion.io>

# Upstash Redis (rate limiting) — optional
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
